---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Converter from '../components/Converter.astro';
import FeatureStrip from '../components/FeatureStrip.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Footer from '../components/Footer.astro';
import { getPopularPairs } from '../lib/formats';

const popular = getPopularPairs();
---

<Layout>
	<NavBar />
	<main>
		<section class="hero">
			<div class="container hero-inner">
				<h1 class="hero-title">Convert any file. Instantly. Privately.</h1>
				<p class="hero-sub">Images, video, audio, PDF &amp; Word — converted right on your device. Nothing is ever uploaded.</p>
				<Converter />
			</div>
		</section>
		<section class="popular">
			<div class="container">
				<h2 class="popular-title">Popular conversions</h2>
				<ul class="popular-grid">
					{
						popular.map((p) => (
							<li>
								<a class="popular-chip" href={`/${p.slug}`}>
									{p.sourceLabel} to {p.targetLabel}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</section>
		<FeatureStrip />
		<HowItWorks />
	</main>
	<Footer />
</Layout>

<style>
	.hero {
		padding: var(--space-4xl) 0 var(--space-5xl);
	}

	.hero-inner {
		text-align: center;
	}

	.hero-title {
		font-size: var(--text-display-xl-size);
		font-weight: var(--text-display-xl-weight);
		line-height: var(--text-display-xl-leading);
		letter-spacing: var(--text-display-xl-tracking);
		color: var(--color-ink);
		margin-bottom: var(--space-sm);
	}

	.hero-sub {
		font-size: var(--text-body-lg-size);
		color: var(--color-body);
		max-width: 560px;
		margin: 0 auto var(--space-2xl);
	}

	.popular {
		padding: 0 0 var(--space-4xl);
	}

	.popular-title {
		font-size: var(--text-body-sm-strong-size);
		font-weight: var(--text-body-sm-strong-weight);
		color: var(--color-mute);
		text-align: center;
		margin-bottom: var(--space-md);
	}

	.popular-grid {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-xs);
		list-style: none;
		padding: 0;
		max-width: 640px;
		margin-inline: auto;
	}

	.popular-chip {
		display: inline-flex;
		font-size: var(--text-body-sm-size);
		color: var(--color-ink);
		background: var(--color-canvas);
		border: 1px solid var(--color-hairline);
		border-radius: var(--radius-pill-sm);
		padding: var(--space-xs) var(--space-md);
		text-decoration: none;
		transition: border-color 0.15s ease;
	}

	.popular-chip:hover {
		border-color: var(--color-ink);
	}

	@media (max-width: 599px) {
		.hero-title {
			font-size: var(--text-display-lg-size);
			line-height: var(--text-display-lg-leading);
			letter-spacing: var(--text-display-lg-tracking);
		}
	}
</style>
