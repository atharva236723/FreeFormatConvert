---
/**
 * Shared shell for the ffmpeg-backed media tools (compress video / audio / gif, trim video).
 * The `mode` prop drives the accepted file types, controls and ffmpeg command that
 * media-tool-controller.ts builds at runtime. The wasm core loads lazily on first use.
 */
import '../styles/tools.css';

interface Props {
	mode: 'compress-video' | 'compress-audio' | 'compress-gif' | 'trim';
	actionLabel?: string;
}

const { mode, actionLabel } = Astro.props;

const ACCEPT: Record<Props['mode'], string> = {
	'compress-video': 'video/*',
	'compress-audio': 'audio/*',
	'compress-gif': 'image/gif',
	trim: 'video/*',
};
const SUB: Record<Props['mode'], string> = {
	'compress-video': 'or click to browse — MP4, MOV, MKV, WebM, AVI & more',
	'compress-audio': 'or click to browse — MP3, WAV, M4A, AAC, OGG & more',
	'compress-gif': 'or click to browse — animated GIF files',
	trim: 'or click to browse — MP4, MOV, MKV, WebM, AVI & more',
};
---

<media-tool class="tool" data-state="idle" data-mode={mode} data-action-label={actionLabel}>
	<div class="tool-dropzone" data-role="dropzone" tabindex="0" role="button" aria-label="Choose a file. Drag and drop, or press to browse.">
		<svg class="tool-dropzone-icon" viewBox="0 0 24 24" aria-hidden="true" width="32" height="32">
			<path d="M12 3v12m0-12 4 4m-4-4-4 4M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
		<p class="tool-dropzone-title">Drop a file</p>
		<p class="tool-dropzone-sub">{SUB[mode]}</p>
		<input type="file" class="visually-hidden" accept={ACCEPT[mode]} data-role="file-input" aria-label="Choose a file" />
	</div>

	<div class="tool-panel">
		<div class="tool-filebar">
			<span class="tool-filename" data-role="file-name"></span>
			<span class="tool-filesize" data-role="file-size"></span>
			<button type="button" class="tool-ghost" data-role="change-file">Change</button>
		</div>

		<div class="tool-stage tool-stage-edit">
			<div class="tool-workspace">
				<div class="tool-preview" data-role="preview"></div>
				<div class="tool-controls" data-role="controls"></div>
			</div>
			<div class="tool-actions">
				<button type="button" class="tool-primary" data-role="apply">Process</button>
			</div>
		</div>

		<div class="tool-stage tool-stage-work">
			<div class="tool-spinner" aria-hidden="true"></div>
			<p class="tool-work-label" data-role="work-label">Processing…</p>
			<p class="tool-work-sub">Your file is processed on your device — the first run downloads the engine once.</p>
			<div class="progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" data-role="progress-track">
				<div class="progress-fill" data-role="progress-fill"></div>
			</div>
		</div>

		<div class="tool-stage tool-stage-done">
			<div class="tool-preview" data-role="result-preview" style="margin-bottom: var(--space-lg)"></div>
			<p class="tool-done-title">Ready</p>
			<p class="tool-done-meta" data-role="done-meta"></p>
			<div class="tool-actions" style="justify-content:center">
				<a class="tool-download" data-role="download" download>
					<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
						<path d="M12 3v12m0 0 4-4m-4 4-4-4M4 19h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
					<span>Download</span>
				</a>
				<button type="button" class="tool-ghost" data-role="restart">Do another</button>
			</div>
		</div>

		<div class="tool-stage tool-stage-error" role="alert">
			<p class="tool-error-msg" data-role="error-message"></p>
			<button type="button" class="tool-ghost" data-role="retry">Try again</button>
		</div>
	</div>

	<div class="visually-hidden" role="status" aria-live="polite" data-role="status"></div>
</media-tool>

<script src="../scripts/media-tool-controller.ts"></script>

<style>
	.progress-track {
		width: 100%;
		max-width: 420px;
		height: 8px;
		margin: var(--space-lg) auto 0;
		background: var(--color-hairline);
		border-radius: var(--radius-full);
		overflow: hidden;
	}

	.progress-fill {
		height: 100%;
		width: 0%;
		background: var(--color-primary);
		border-radius: var(--radius-full);
		transition: width 0.2s ease;
	}
</style>
