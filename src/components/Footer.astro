---
import { getPopularPairs, type ConversionPair, type FileCategory } from '../lib/formats';

const year = new Date().getFullYear();

// Popular conversions grouped by the category of the file you start with — kept in
// sync with formats.ts, exactly like the NavBar's "Conversions" mega-menu.
const CATEGORY_TITLES: Record<FileCategory, string> = {
	image: 'Images',
	video: 'Video',
	audio: 'Audio',
	document: 'Documents',
};
const CATEGORY_ORDER: FileCategory[] = ['image', 'video', 'audio', 'document'];

const grouped: Record<FileCategory, ConversionPair[]> = { image: [], video: [], audio: [], document: [] };
for (const pair of getPopularPairs(30)) {
	grouped[pair.sourceCategory].push(pair);
}
const convertColumns = CATEGORY_ORDER.map((category) => ({
	title: CATEGORY_TITLES[category],
	pairs: grouped[category].slice(0, 5),
})).filter((column) => column.pairs.length > 0);

// Category hub pages (not (source → target) pairs).
const toolLinks = [
	{ href: '/pdf-converter', label: 'PDF converter' },
	{ href: '/document-converter', label: 'Document converter' },
	{ href: '/ebook-converter', label: 'Ebook converter' },
	{ href: '/video-to-gif', label: 'Video to GIF' },
	{ href: '/image-to-gif', label: 'Image to GIF' },
	{ href: '/conversions', label: 'All conversions' },
];

const companyLinks = [
	{ href: '/about', label: 'About' },
	{ href: '/contact', label: 'Contact' },
	{ href: '/terms', label: 'Terms' },
	{ href: '/privacy', label: 'Privacy' },
];
---

<footer class="footer">
	<div class="container footer-inner">
		<div class="footer-brand">
			<a href="/" class="footer-logo">Free Format Convert</a>
			<p class="footer-tagline">
				Free image, video, audio and document conversion that runs entirely in your browser.
				Your files never leave your device.
			</p>
		</div>

		<nav class="footer-cols" aria-label="Footer">
			{
				convertColumns.map((column) => (
					<div class="footer-col">
						<p class="footer-col-title">{column.title}</p>
						<ul>
							{column.pairs.map((p) => (
								<li>
									<a href={`/${p.slug}`}>
										{p.sourceLabel} to {p.targetLabel}
									</a>
								</li>
							))}
						</ul>
					</div>
				))
			}
			<div class="footer-col">
				<p class="footer-col-title">Tools</p>
				<ul>
					{toolLinks.map((link) => (
						<li><a href={link.href}>{link.label}</a></li>
					))}
				</ul>
			</div>
			<div class="footer-col">
				<p class="footer-col-title">Company</p>
				<ul>
					{companyLinks.map((link) => (
						<li><a href={link.href}>{link.label}</a></li>
					))}
				</ul>
			</div>
		</nav>
	</div>

	<div class="container footer-bottom">
		<span>© {year} Free Format Convert</span>
		<span>Converted entirely on your device.</span>
	</div>
</footer>

<style>
	.footer {
		background: var(--color-chrome);
		border-top: 1px solid var(--color-chrome-border);
		padding: var(--space-2xl) 0 var(--space-xl);
	}

	.footer-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 2.4fr);
		gap: var(--space-2xl);
		align-items: start;
	}

	.footer-logo {
		font-size: var(--text-display-sm-size);
		font-weight: var(--text-display-sm-weight);
		letter-spacing: var(--text-display-sm-tracking);
		color: var(--color-chrome-fg);
		text-decoration: none;
	}

	.footer-tagline {
		margin-top: var(--space-sm);
		max-width: 34ch;
		font-size: var(--text-body-sm-size);
		line-height: 1.6;
		color: var(--color-chrome-fg-muted);
	}

	.footer-cols {
		display: grid;
		grid-template-columns: repeat(6, minmax(0, 1fr));
		gap: var(--space-lg);
	}

	.footer-col-title {
		font-size: var(--text-caption-size);
		font-weight: var(--text-body-sm-strong-weight);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-chrome-fg-muted);
		margin-bottom: var(--space-sm);
	}

	.footer-col ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.footer-col a {
		font-size: var(--text-body-sm-size);
		color: var(--color-chrome-fg-muted);
		text-decoration: none;
	}

	.footer-col a:hover {
		color: var(--color-chrome-fg);
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: var(--space-md);
		margin-top: var(--space-2xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-chrome-border);
		font-size: var(--text-body-sm-size);
		color: var(--color-chrome-fg-muted);
	}

	@media (max-width: 899px) {
		.footer-inner {
			grid-template-columns: 1fr;
			gap: var(--space-xl);
		}

		.footer-cols {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 599px) {
		.footer-cols {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: var(--space-lg) var(--space-md);
		}

		.footer-bottom {
			flex-direction: column;
			gap: var(--space-xs);
		}
	}
</style>
