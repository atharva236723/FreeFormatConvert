---
const steps = [
	{ n: '01', title: 'Drop your file', body: 'Any image, video, audio, PDF, or Word file — drag it in or click to browse.' },
	{ n: '02', title: 'Pick a format', body: 'Choose from popular formats, or expand to see every format we support.' },
	{ n: '03', title: 'Download', body: 'Your converted file downloads straight to your device. That’s it.' },
];
---

<section id="how-it-works" class="how-it-works">
	<div class="container">
		<p class="eyebrow">How it works</p>
		<h2 class="heading">Three steps. No account needed.</h2>
		<div class="steps-grid">
			{
				steps.map((s) => (
					<div class="step">
						<span class="step-number">{s.n}</span>
						<p class="step-title">{s.title}</p>
						<p class="step-body">{s.body}</p>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.how-it-works {
		position: relative;
		background: var(--color-canvas-soft);
		border-top: 1px solid var(--color-hairline);
		border-bottom: 1px solid var(--color-hairline);
		padding: var(--space-5xl) 0;
	}

	.eyebrow {
		font-family: var(--font-mono);
		font-size: var(--text-caption-mono-size);
		color: var(--color-mute);
		margin-bottom: var(--space-sm);
	}

	.heading {
		font-size: var(--text-display-lg-size);
		font-weight: var(--text-display-lg-weight);
		line-height: var(--text-display-lg-leading);
		letter-spacing: var(--text-display-lg-tracking);
		color: var(--color-ink);
		margin-bottom: var(--space-3xl);
	}

	.steps-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-xl);
	}

	.step {
		position: relative;
	}

	/* Numbered token: a gradient-outlined pill that reads as a real step marker. */
	.step-number {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		border-radius: var(--radius-md);
		font-family: var(--font-mono);
		font-size: var(--text-body-sm-strong-size);
		font-weight: 600;
		color: var(--color-ink);
		background: var(--color-canvas);
		border: 1px solid var(--color-hairline);
		box-shadow: var(--shadow-level-2);
		margin-bottom: var(--space-md);
	}

	.step-title {
		font-size: var(--text-display-sm-size);
		font-weight: var(--text-display-sm-weight);
		letter-spacing: var(--text-display-sm-tracking);
		color: var(--color-ink);
		margin: var(--space-xxs) 0 var(--space-xs);
	}

	.step-body {
		font-size: var(--text-body-md-size);
		line-height: 1.6;
		color: var(--color-body);
	}

	/* Connector line between step markers on wide layouts. */
	@media (min-width: 960px) {
		.step:not(:last-child)::after {
			content: '';
			position: absolute;
			top: 22px;
			left: 56px;
			right: calc(-1 * var(--space-xl));
			height: 1px;
			background: linear-gradient(90deg, var(--color-hairline-strong), transparent);
		}
	}

	@media (max-width: 959px) {
		.steps-grid {
			grid-template-columns: 1fr;
			gap: var(--space-2xl);
		}
	}
</style>
