---
import { getPopularPairs, type ConversionPair, type FileCategory } from '../lib/formats';

// Group the curated popular conversions by the category of the file you start with,
// so the menu reads "Images → …", "Video → …" etc. Kept in sync with formats.ts.
const CATEGORY_TITLES: Record<FileCategory, string> = {
	image: 'Images',
	video: 'Video',
	audio: 'Audio',
	document: 'Documents',
};
const CATEGORY_ORDER: FileCategory[] = ['image', 'video', 'audio', 'document'];

const grouped: Record<FileCategory, ConversionPair[]> = { image: [], video: [], audio: [], document: [] };
for (const pair of getPopularPairs(30)) {
	grouped[pair.sourceCategory].push(pair);
}
const menuColumns = CATEGORY_ORDER.map((category) => ({
	title: CATEGORY_TITLES[category],
	pairs: grouped[category].slice(0, 7),
})).filter((column) => column.pairs.length > 0);

// Category hub pages (not (source → target) pairs) surfaced along the bottom of the menu.
const hubLinks = [
	{ href: '/pdf-converter', label: 'PDF converter' },
	{ href: '/document-converter', label: 'Document converter' },
	{ href: '/ebook-converter', label: 'Ebook converter' },
	{ href: '/video-to-gif', label: 'Video to GIF' },
	{ href: '/image-to-gif', label: 'Image to GIF' },
];
---

<header class="nav-bar">
	<div class="container nav-inner">
		<a href="/" class="logo">
			<img class="logo-mark" src="/favicon.svg" alt="" width="28" height="28" aria-hidden="true" />
			Free Format Convert
		</a>
		<nav class="nav-links" aria-label="Primary">
			<div class="nav-dropdown" data-dropdown>
				<button
					type="button"
					class="nav-dropdown-trigger"
					data-dropdown-trigger
					aria-haspopup="true"
					aria-expanded="false"
					aria-controls="conversions-menu"
				>
					Conversions
					<svg class="chevron" viewBox="0 0 24 24" aria-hidden="true">
						<path d="m6 9 6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
				</button>
				<div class="nav-dropdown-panel" id="conversions-menu" data-dropdown-panel hidden>
					<div class="dropdown-grid">
						{
							menuColumns.map((column) => (
								<div class="dropdown-col">
									<p class="dropdown-col-title">{column.title}</p>
									<ul>
										{column.pairs.map((p) => (
											<li>
												<a href={`/${p.slug}`}>
													{p.sourceLabel} to {p.targetLabel}
												</a>
											</li>
										))}
									</ul>
								</div>
							))
						}
					</div>
					<div class="dropdown-hubs">
						{hubLinks.map((hub) => <a href={hub.href}>{hub.label}</a>)}
					</div>
					<a class="dropdown-all" href="/conversions">
						View all conversions
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path d="M5 12h14m-6-6 6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
						</svg>
					</a>
				</div>
			</div>
			<a href="/about">About</a>
			<a href="/contact">Contact</a>
			<a href="/terms">Terms</a>
			<a href="/privacy">Privacy</a>
		</nav>
		<button
			type="button"
			class="theme-toggle"
			data-theme-toggle
			aria-pressed="false"
			aria-label="Toggle dark mode"
		>
			<span class="theme-toggle-track">
				<span class="theme-toggle-thumb">
					<svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true">
						<circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2" />
						<path
							d="M12 2v2m0 16v2M4.2 4.2l1.4 1.4m12.8 12.8 1.4 1.4M2 12h2m16 0h2M4.2 19.8l1.4-1.4m12.8-12.8 1.4-1.4"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
						></path>
					</svg>
					<svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true">
						<path
							d="M20 14.5A8.5 8.5 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5Z"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linejoin="round"
						></path>
					</svg>
				</span>
			</span>
		</button>
		<script is:inline>
			document.querySelectorAll('[data-theme-toggle]').forEach(function (btn) {
				btn.setAttribute('aria-pressed', document.documentElement.getAttribute('data-theme') === 'dark' ? 'true' : 'false');
			});
		</script>
	</div>
</header>

<style>
	.nav-bar {
		background: var(--color-chrome);
		border-bottom: 1px solid var(--color-chrome-border);
	}

	.nav-inner {
		position: relative;
		min-height: 64px;
		display: flex;
		align-items: center;
		gap: var(--space-md);
		flex-wrap: wrap;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
		font-size: var(--text-display-sm-size);
		font-weight: var(--text-display-sm-weight);
		letter-spacing: var(--text-display-sm-tracking);
		color: var(--color-chrome-fg);
		text-decoration: none;
		white-space: nowrap;
	}

	.logo-mark {
		display: block;
		width: 28px;
		height: 28px;
		flex-shrink: 0;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: var(--space-md);
		margin-left: auto;
	}

	.nav-links > a {
		font-size: var(--text-body-sm-size);
		color: var(--color-chrome-fg-muted);
		text-decoration: none;
		padding: var(--space-xs) var(--space-sm);
		border-radius: var(--radius-full);
	}

	.nav-links > a:hover {
		background: var(--color-chrome-hover);
		color: var(--color-chrome-fg);
	}

	/* Conversions dropdown */
	.nav-dropdown {
		position: relative;
	}

	.nav-dropdown-trigger {
		appearance: none;
		background: none;
		border: none;
		cursor: pointer;
		font-family: inherit;
		font-size: var(--text-body-sm-size);
		color: var(--color-chrome-fg-muted);
		display: inline-flex;
		align-items: center;
		gap: var(--space-xxs);
		padding: var(--space-xs) var(--space-sm);
		border-radius: var(--radius-full);
	}

	.nav-dropdown-trigger:hover,
	.nav-dropdown-trigger[aria-expanded='true'] {
		background: var(--color-chrome-hover);
		color: var(--color-chrome-fg);
	}

	.nav-dropdown-trigger .chevron {
		width: 14px;
		height: 14px;
		transition: transform 0.15s ease;
	}

	.nav-dropdown-trigger[aria-expanded='true'] .chevron {
		transform: rotate(180deg);
	}

	.nav-dropdown-panel {
		position: absolute;
		top: calc(100% + var(--space-xs));
		left: 0;
		z-index: 50;
		width: min(600px, calc(100vw - 2 * var(--space-md)));
		background: var(--color-canvas);
		border: 1px solid var(--color-hairline);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-level-4);
		padding: var(--space-lg);
	}

	.nav-dropdown-panel[hidden] {
		display: none;
	}

	.dropdown-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-lg);
	}

	.dropdown-col-title {
		font-size: var(--text-caption-size);
		font-weight: var(--text-body-sm-strong-weight);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-mute);
		margin-bottom: var(--space-xs);
	}

	.dropdown-col ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.dropdown-col a {
		display: block;
		font-size: var(--text-body-sm-size);
		color: var(--color-body);
		text-decoration: none;
		padding: var(--space-xxs) var(--space-xs);
		margin: 0 calc(-1 * var(--space-xs));
		border-radius: var(--radius-sm);
		white-space: nowrap;
	}

	.dropdown-col a:hover {
		background: var(--color-canvas-soft-2);
		color: var(--color-ink);
	}

	.dropdown-hubs {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs) var(--space-md);
		margin-top: var(--space-lg);
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-hairline);
	}

	.dropdown-hubs a {
		font-size: var(--text-body-sm-size);
		font-weight: var(--text-body-sm-strong-weight);
		color: var(--color-ink);
		text-decoration: none;
	}

	.dropdown-hubs a:hover {
		color: var(--color-link);
	}

	.dropdown-all {
		display: inline-flex;
		align-items: center;
		gap: var(--space-xxs);
		margin-top: var(--space-md);
		font-size: var(--text-body-sm-size);
		font-weight: var(--text-body-sm-strong-weight);
		color: var(--color-link);
		text-decoration: none;
	}

	.dropdown-all svg {
		width: 15px;
		height: 15px;
		transition: transform 0.15s ease;
	}

	.dropdown-all:hover svg {
		transform: translateX(3px);
	}

	/* Two-up columns once the four-column grid gets cramped. */
	@media (max-width: 767px) {
		.dropdown-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 599px) {
		.nav-inner {
			padding-top: var(--space-sm);
			padding-bottom: var(--space-sm);
		}

		.nav-links {
			order: 3;
			width: 100%;
			margin-left: 0;
			justify-content: center;
			flex-wrap: wrap;
			gap: var(--space-xs) var(--space-sm);
			padding-top: var(--space-sm);
			border-top: 1px solid var(--color-chrome-border);
		}

		/* Center the panel under the wrapped link row instead of anchoring it to
		   the (now centered) trigger, so it can't overflow the viewport edge. */
		.nav-dropdown {
			position: static;
		}

		.nav-dropdown-panel {
			left: 50%;
			transform: translateX(-50%);
			padding: var(--space-md);
		}

		.theme-toggle {
			margin-left: auto;
		}
	}

	.theme-toggle {
		appearance: none;
		background: none;
		border: none;
		padding: 0;
		display: inline-flex;
		border-radius: var(--radius-full);
	}

	.theme-toggle-track {
		position: relative;
		width: 44px;
		height: 24px;
		border-radius: var(--radius-full);
		background: var(--color-canvas-soft-2);
		box-shadow: var(--shadow-level-1);
		transition: background-color 0.2s ease;
	}

	.theme-toggle-thumb {
		position: absolute;
		top: 2px;
		left: 2px;
		width: 20px;
		height: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-full);
		background: var(--color-canvas);
		box-shadow: var(--shadow-level-2);
		transition: transform 0.2s ease;
	}

	.theme-toggle-thumb svg {
		width: 13px;
		height: 13px;
		color: var(--color-mute);
	}

	.theme-toggle-thumb .icon-moon {
		display: none;
	}

	.theme-toggle[aria-pressed='true'] .theme-toggle-track {
		background: var(--color-chrome-hover);
	}

	.theme-toggle[aria-pressed='true'] .theme-toggle-thumb {
		transform: translateX(20px);
	}

	.theme-toggle[aria-pressed='true'] .icon-sun {
		display: none;
	}

	.theme-toggle[aria-pressed='true'] .icon-moon {
		display: block;
	}
</style>

<script src="../scripts/theme-toggle.ts"></script>
<script src="../scripts/nav-dropdown.ts"></script>
