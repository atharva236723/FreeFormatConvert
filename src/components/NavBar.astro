---
---

<header class="nav-bar">
	<div class="container nav-inner">
		<span class="logo">Formart</span>
		<div class="nav-right">
			<nav class="nav-links">
				<a href="#how-it-works">How it works</a>
				<a href="#faq">FAQ</a>
			</nav>
			<button
				type="button"
				class="theme-toggle"
				data-theme-toggle
				aria-pressed="false"
				aria-label="Toggle dark mode"
			>
				<span class="theme-toggle-track">
					<span class="theme-toggle-thumb">
						<svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true">
							<circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2" />
							<path
								d="M12 2v2m0 16v2M4.2 4.2l1.4 1.4m12.8 12.8 1.4 1.4M2 12h2m16 0h2M4.2 19.8l1.4-1.4m12.8-12.8 1.4-1.4"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
							></path>
						</svg>
						<svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true">
							<path
								d="M20 14.5A8.5 8.5 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5Z"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linejoin="round"
							></path>
						</svg>
					</span>
				</span>
			</button>
			<script is:inline>
				document.querySelectorAll('[data-theme-toggle]').forEach(function (btn) {
					btn.setAttribute('aria-pressed', document.documentElement.getAttribute('data-theme') === 'dark' ? 'true' : 'false');
				});
			</script>
		</div>
	</div>
</header>

<style>
	.nav-bar {
		background: var(--color-canvas);
		border-bottom: 1px solid var(--color-hairline);
	}

	.nav-inner {
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		font-size: var(--text-display-sm-size);
		font-weight: var(--text-display-sm-weight);
		letter-spacing: var(--text-display-sm-tracking);
		color: var(--color-ink);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: var(--space-md);
	}

	.nav-links {
		display: flex;
		gap: var(--space-md);
	}

	.nav-links a {
		font-size: var(--text-body-sm-size);
		color: var(--color-body);
		text-decoration: none;
		padding: var(--space-xs) var(--space-sm);
		border-radius: var(--radius-full);
	}

	.nav-links a:hover {
		background: var(--color-canvas-soft);
		color: var(--color-ink);
	}

	@media (max-width: 599px) {
		.nav-links {
			display: none;
		}
	}

	.theme-toggle {
		appearance: none;
		background: none;
		border: none;
		padding: 0;
		display: inline-flex;
		border-radius: var(--radius-full);
	}

	.theme-toggle-track {
		position: relative;
		width: 44px;
		height: 24px;
		border-radius: var(--radius-full);
		background: var(--color-canvas-soft-2);
		box-shadow: var(--shadow-level-1);
		transition: background-color 0.2s ease;
	}

	.theme-toggle-thumb {
		position: absolute;
		top: 2px;
		left: 2px;
		width: 20px;
		height: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-full);
		background: var(--color-canvas);
		box-shadow: var(--shadow-level-2);
		transition: transform 0.2s ease;
	}

	.theme-toggle-thumb svg {
		width: 13px;
		height: 13px;
		color: var(--color-mute);
	}

	.theme-toggle-thumb .icon-moon {
		display: none;
	}

	.theme-toggle[aria-pressed='true'] .theme-toggle-track {
		background: var(--color-ink);
	}

	.theme-toggle[aria-pressed='true'] .theme-toggle-thumb {
		transform: translateX(20px);
	}

	.theme-toggle[aria-pressed='true'] .icon-sun {
		display: none;
	}

	.theme-toggle[aria-pressed='true'] .icon-moon {
		display: block;
	}
</style>

<script src="../scripts/theme-toggle.ts"></script>
