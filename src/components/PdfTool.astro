---
/**
 * Shared shell for the pdf-lib-backed PDF tools (merge / split / rotate / remove / extract).
 * The `mode` prop drives what pdf-tool-controller.ts builds at runtime: merge shows a reorderable
 * file list, the page modes show a selectable thumbnail grid (rendered via pdfjs). Everything
 * runs on-device — PDFs are never uploaded.
 */
import '../styles/tools.css';

interface Props {
	mode: 'merge' | 'split' | 'rotate' | 'remove' | 'extract';
	actionLabel?: string;
}

const { mode, actionLabel } = Astro.props;
const dropTitle = mode === 'merge' ? 'Drop PDF files' : 'Drop a PDF';
const dropSub = mode === 'merge' ? 'or click to browse — add two or more PDFs to combine' : 'or click to browse — a single PDF file';
---

<pdf-tool class="tool" data-state="idle" data-mode={mode} data-action-label={actionLabel}>
	<div class="tool-dropzone" data-role="dropzone" tabindex="0" role="button" aria-label="Choose PDF files. Drag and drop, or press to browse.">
		<svg class="tool-dropzone-icon" viewBox="0 0 24 24" aria-hidden="true" width="32" height="32">
			<path d="M12 3v12m0-12 4 4m-4-4-4 4M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
		<p class="tool-dropzone-title">{dropTitle}</p>
		<p class="tool-dropzone-sub">{dropSub}</p>
		<input type="file" class="visually-hidden" accept="application/pdf,.pdf" multiple={mode === 'merge'} data-role="file-input" aria-label="Choose PDF files" />
	</div>

	<div class="tool-panel">
		<div class="tool-filebar" data-role="filebar" hidden>
			<span class="tool-filename" data-role="file-name"></span>
			<span class="tool-filesize" data-role="file-size"></span>
			<button type="button" class="tool-ghost" data-role="change-file">Change</button>
		</div>

		<div class="tool-stage tool-stage-edit">
			<div data-role="controls"></div>
			<div data-role="workarea"></div>
			<div class="tool-actions">
				<button type="button" class="tool-primary" data-role="apply">Apply</button>
			</div>
		</div>

		<div class="tool-stage tool-stage-work">
			<div class="tool-spinner" aria-hidden="true"></div>
			<p class="tool-work-label" data-role="work-label">Working…</p>
			<p class="tool-work-sub">Your PDF is processed on your device — nothing is uploaded.</p>
		</div>

		<div class="tool-stage tool-stage-done">
			<div class="tool-done-badge" aria-hidden="true">
				<svg viewBox="0 0 24 24" width="40" height="40">
					<circle cx="12" cy="12" r="11" fill="var(--color-primary)"></circle>
					<path d="M7 12.5l3 3 7-7" fill="none" stroke="var(--color-on-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
			</div>
			<p class="tool-done-title">Ready</p>
			<p class="tool-done-meta" data-role="done-meta"></p>
			<div class="tool-actions" style="justify-content:center">
				<a class="tool-download" data-role="download" download>
					<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
						<path d="M12 3v12m0 0 4-4m-4 4-4-4M4 19h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
					<span>Download</span>
				</a>
				<button type="button" class="tool-ghost" data-role="restart">Start over</button>
			</div>
		</div>

		<div class="tool-stage tool-stage-error" role="alert">
			<p class="tool-error-msg" data-role="error-message"></p>
			<button type="button" class="tool-ghost" data-role="retry">Try again</button>
		</div>
	</div>

	<div class="visually-hidden" role="status" aria-live="polite" data-role="status"></div>
</pdf-tool>

<script src="../scripts/pdf-tool-controller.ts"></script>
