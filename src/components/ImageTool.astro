---
/**
 * Shared shell for the Canvas-based image tools (resize / crop / rotate / flip / compress /
 * color-picker). The `mode` prop drives which controls image-tool-controller.ts builds at
 * runtime, so one component + one controller cover every image tool. Everything runs on-device.
 */
import '../styles/tools.css';

interface Props {
	mode: 'resize' | 'crop' | 'rotate' | 'flip' | 'compress' | 'colorpicker';
	/** Verb shown on the primary action button, e.g. "Resize image". */
	actionLabel?: string;
}

const { mode, actionLabel } = Astro.props;
---

<image-tool class="tool" data-state="idle" data-mode={mode} data-action-label={actionLabel}>
	<div class="tool-dropzone" data-role="dropzone" tabindex="0" role="button" aria-label="Choose an image. Drag and drop, or press to browse.">
		<svg class="tool-dropzone-icon" viewBox="0 0 24 24" aria-hidden="true" width="32" height="32">
			<path d="M12 3v12m0-12 4 4m-4-4-4 4M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
		<p class="tool-dropzone-title">Drop an image</p>
		<p class="tool-dropzone-sub">or click to browse — JPG, PNG, WebP, GIF, SVG & more</p>
		<input type="file" class="visually-hidden" accept="image/*" data-role="file-input" aria-label="Choose an image" />
	</div>

	<div class="tool-panel">
		<div class="tool-filebar">
			<span class="tool-filename" data-role="file-name"></span>
			<span class="tool-filesize" data-role="file-size"></span>
			<button type="button" class="tool-ghost" data-role="change-file">Change</button>
		</div>

		<div class="tool-stage tool-stage-edit">
			<div class="tool-workspace">
				<div class="tool-preview" data-role="preview"></div>
				<div class="tool-controls" data-role="controls"></div>
			</div>
			<div class="tool-actions">
				<button type="button" class="tool-primary" data-role="apply">Apply</button>
			</div>
		</div>

		<div class="tool-stage tool-stage-work">
			<div class="tool-spinner" aria-hidden="true"></div>
			<p class="tool-work-label">Working…</p>
			<p class="tool-work-sub">Everything happens on your device — nothing is uploaded.</p>
		</div>

		<div class="tool-stage tool-stage-done">
			<div class="tool-preview" data-role="result-preview" style="margin-bottom: var(--space-lg)"></div>
			<p class="tool-done-title">Ready</p>
			<p class="tool-done-meta" data-role="done-meta"></p>
			<div class="tool-actions" style="justify-content:center">
				<a class="tool-download" data-role="download" download>
					<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
						<path d="M12 3v12m0 0 4-4m-4 4-4-4M4 19h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
					<span>Download</span>
				</a>
				<button type="button" class="tool-ghost" data-role="restart">Edit another</button>
			</div>
		</div>

		<div class="tool-stage tool-stage-error" role="alert">
			<p class="tool-error-msg" data-role="error-message"></p>
			<button type="button" class="tool-ghost" data-role="retry">Try again</button>
		</div>
	</div>

	<div class="visually-hidden" role="status" aria-live="polite" data-role="status"></div>
</image-tool>

<script src="../scripts/image-tool-controller.ts"></script>
