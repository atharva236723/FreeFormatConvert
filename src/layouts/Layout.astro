---
import { Font } from 'astro:assets';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Formart — Convert any image, video, or audio file, privately',
	description = 'Convert images, video, and audio between formats entirely in your browser. No uploads, no size limits, no sign-up.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<Font cssVariable="--font-geist-sans" preload />
		<Font cssVariable="--font-geist-mono" />
	</head>
	<body>
		<slot />
	</body>
</html>
